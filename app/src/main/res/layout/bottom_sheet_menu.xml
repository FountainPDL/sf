<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_sheet_handle" />

    <!-- Row 1: Main actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <LinearLayout android:id="@+id/menu_add_bookmark" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_bookmark_add" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bookmark" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_new_tab" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_add" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Tab" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_incognito" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_incognito" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Incognito" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_share" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_share" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Share" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_screenshot" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_screenshot" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Screenshot" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="?attr/colorOnSurface" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" />

    <!-- List items -->
    <LinearLayout android:id="@+id/menu_ai" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_ai" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Surf AI" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_reader_mode" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_reader_mode" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reader Mode" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_find_in_page" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_find_in_page" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find in Page" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_desktop_mode" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_desktop" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Desktop Mode" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" />

    <LinearLayout android:id="@+id/menu_bookmarks" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_bookmarks" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bookmarks" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_history" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_history" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_downloads" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_download" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Downloads" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_privacy" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_shield_secure" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Privacy Center" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_wallet" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_wallet" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Surf Wallet" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_vpn" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_vpn" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Surf VPN" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_qr" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_qr" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QR Code" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_dev_tools" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_code" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Developer Tools" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_settings" android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_settings" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="15sp" android:textColor="?attr/colorOnSurface" />
    </LinearLayout>
</LinearLayout>
